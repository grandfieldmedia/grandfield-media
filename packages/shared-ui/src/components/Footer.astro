---

<footer class="mt-24 border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-5">
      <div class="col-span-2 lg:col-span-2">
        <a href="/" class="text-lg font-bold text-primary">{site.brand}</a>
        <p class="mt-3 max-w-xs text-sm text-slate-600 dark:text-slate-400">{site.tagline}</p>
        {site.social.length > 0 && (
          <div class="mt-5 flex gap-4">
            {site.social.map((s) => (
              <a href={s.href} aria-label={s.label} class="text-slate-500 transition-colors hover:text-primary" target="_blank" rel="noopener">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d={socialPaths[s.icon]} /></svg>
              </a>
            ))}
          </div>
        )}
      </div>

      {site.footerColumns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">{col.title}</h3>
          <ul class="mt-4 space-y-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-slate-600 transition-colors hover:text-primary dark:text-slate-400">{link.text}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-slate-200 pt-8 sm:flex-row sm:items-center sm:justify-between dark:border-slate-800">
      <p class="text-sm text-slate-500">&copy; {year} {site.brand}. All rights reserved.</p>
      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        {site.legalLinks.map((link) => (
          <li><a href={link.href} class="text-sm text-slate-500 hover:text-primary">{link.text}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>
