---
import type { SiteConfig } from '../types';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

// Wordmark: "Grandfield" (muted) + niche word (primary). Falls back gracefully.
const words = site.brand.split(' ');
const lead = words.length > 1 ? words.slice(0, -1).join(' ') : '';
const niche = words[words.length - 1];
// The Grandfield 3x3 grid mark: 8 light cells + 1 accent cell (top-right).
const cells = [0, 1, 2, 3, 4, 5, 6, 7, 8];
const accentCell = 2; // top-right
---

<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/90 backdrop-blur dark:border-slate-800 dark:bg-slate-950/90">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2.5" aria-label={site.brand}>
      {site.logo ? (
        <img src={site.logo} alt={site.brand} class="h-9 w-auto" />
      ) : (
        <>
          <span class="grid grid-cols-3 gap-[3px] rounded-[10px] bg-primary p-[7px]" aria-hidden="true">
            {cells.map((c) => (
              <span class:list={['h-[6px] w-[6px] rounded-[2px]', c === accentCell ? 'bg-accent' : 'bg-white/85']}></span>
            ))}
          </span>
          <span class="text-lg font-bold leading-none text-primary">
            {lead && <span class="font-semibold text-slate-500 dark:text-slate-400">{lead}&nbsp;</span>}{niche}
          </span>
        </>
      )}
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {site.nav.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary',
            isActive(link.href) ? 'text-primary' : 'text-slate-600 dark:text-slate-300',
          ]}
        >
          {link.text}
        </a>
      ))}
    </nav>

    <button
      id="gf-menu-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-slate-600 hover:bg-slate-100 md:hidden dark:text-slate-300 dark:hover:bg-slate-800"
      aria-label="Toggle navigation menu"
      aria-controls="gf-mobile-menu"
      aria-expanded="false"
    >
      <svg data-icon="open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg data-icon="close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div id="gf-mobile-menu" class="hidden border-t border-slate-200 md:hidden dark:border-slate-800">
    <nav class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3 sm:px-6">
      {site.nav.map((link) => (
        <a href={link.href} class="rounded-md px-3 py-2 text-base text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-800">
          {link.text}
        </a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('gf-menu-toggle');
    var menu = document.getElementById('gf-mobile-menu');
    if (!btn || !menu) return;
    var openIcon = btn.querySelector('[data-icon="open"]');
    var closeIcon = btn.querySelector('[data-icon="close"]');
    btn.addEventListener('click', function () {
      var isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden', !isOpen);
      closeIcon.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  })();
</script>
