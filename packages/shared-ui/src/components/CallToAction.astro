---
import type { CtaAction } from '../types';
import Section from './Section.astro';

interface Props {
  title: string;
  subtitle?: string;
  actions: CtaAction[];
}

const { title, subtitle, actions } = Astro.props;
---

<Section>
  <div class="rounded-2xl bg-primary px-6 py-16 text-center text-white sm:px-16">
    <h2 class="mx-auto max-w-2xl text-3xl font-bold sm:text-4xl">{title}</h2>
    {subtitle && <p class="mx-auto mt-4 max-w-xl text-lg text-slate-200">{subtitle}</p>}
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      {actions.map((a) => (
        <a
          href={a.href}
          class:list={[
            'rounded-lg px-8 py-3 font-semibold transition',
            a.primary !== false
              ? 'bg-accent text-primary hover:bg-accent-light'
              : 'border border-white/30 text-white hover:bg-white/10',
          ]}
        >
          {a.text}
        </a>
      ))}
    </div>
  </div>
</Section>
