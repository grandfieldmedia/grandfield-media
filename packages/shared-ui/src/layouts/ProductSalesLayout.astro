---
import type { ProductSummary, FeatureItem, FaqItem } from '../types';
import { formatPrice } from '../utils';

/**
 * Reusable one-time-purchase sales page body. Uses the SAME site nav/footer as
 * every other page (rendered by the site's Layout wrapper) — the doc's
 * deliberate consistency-over-CRO choice. Prop-driven; no brand specifics.
 */
interface Props {
  product: ProductSummary;
  benefits?: FeatureItem[];
  faqs?: FaqItem[];
  /** True once Stripe keys are configured; gates the buy button. */
  checkoutEnabled: boolean;
  checkoutAction?: string; // POST endpoint, default /api/checkout
}

const {
  product,
  benefits = [],
  faqs = [],
  checkoutEnabled,
  checkoutAction = '/api/checkout',
} = Astro.props;
---

<article>
  <!-- Hero -->
  <section class="bg-primary text-white">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:items-center lg:py-24">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wider text-accent">Digital download</p>
        <h1 class="mt-3 text-4xl font-bold leading-tight sm:text-5xl">{product.name}</h1>
        {product.description && <p class="mt-5 text-lg text-slate-200">{product.description}</p>}

        <div class="mt-8 flex items-center gap-4">
          <span class="text-3xl font-bold">{formatPrice(product.price)}</span>
          <span class="text-sm text-slate-300">one-time · instant download</span>
        </div>

        <div class="mt-8">
          {checkoutEnabled ? (
            <form method="POST" action={checkoutAction}>
              <input type="hidden" name="slug" value={product.slug} />
              <button type="submit" class="rounded-lg bg-accent px-8 py-3.5 text-lg font-semibold text-primary transition hover:bg-accent-light">
                Buy now — {formatPrice(product.price)}
              </button>
            </form>
          ) : (
            <div>
              <button type="button" disabled class="cursor-not-allowed rounded-lg bg-white/20 px-8 py-3.5 text-lg font-semibold text-white/70">
                Checkout coming soon
              </button>
              <p class="mt-2 text-sm text-slate-300">Payments are being set up — check back shortly.</p>
            </div>
          )}
        </div>
      </div>

      <div class="flex items-center justify-center">
        {product.image
          ? <img src={product.image} alt={product.name} class="max-h-96 w-auto rounded-xl shadow-2xl" />
          : <div class="flex h-72 w-full max-w-sm items-center justify-center rounded-xl bg-white/10 text-6xl font-bold text-white/40">{product.name.charAt(0)}</div>}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  {benefits.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <h2 class="mb-10 text-center text-3xl font-bold text-primary">What's inside</h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {benefits.map((b) => (
          <div class="rounded-xl border border-slate-200 p-6 dark:border-slate-800">
            <h3 class="font-semibold text-primary">{b.title}</h3>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{b.description}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faqs.length > 0 && (
    <section class="bg-slate-50 dark:bg-slate-900">
      <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
        <h2 class="mb-8 text-center text-3xl font-bold text-primary">Questions</h2>
        <div class="divide-y divide-slate-200 dark:divide-slate-800">
          {faqs.map((f) => (
            <details class="group py-5">
              <summary class="cursor-pointer text-lg font-medium text-slate-900 dark:text-slate-100">{f.question}</summary>
              <p class="mt-3 text-slate-600 dark:text-slate-400">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6">
    <h2 class="text-2xl font-bold text-primary">Get {product.name} today</h2>
    <p class="mt-3 text-slate-600 dark:text-slate-400">Instant download, yours to keep, {formatPrice(product.price)}.</p>
    {checkoutEnabled ? (
      <form method="POST" action={checkoutAction} class="mt-6">
        <input type="hidden" name="slug" value={product.slug} />
        <button type="submit" class="rounded-lg bg-primary px-8 py-3 font-semibold text-white transition hover:bg-primary-light">
          Buy now — {formatPrice(product.price)}
        </button>
      </form>
    ) : (
      <p class="mt-6 text-sm text-slate-500">Checkout coming soon.</p>
    )}
  </section>
</article>
