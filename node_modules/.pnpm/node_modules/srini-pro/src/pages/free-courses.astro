---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="Free SAP Integration Courses" description="Free lifetime access to SAP BTP Basics, SAP Integration Suite Basics, API, REST & JSON, Cloud Computing, and SAP AI Basics.">
  <div class="space-y-12">
    <h1 class="text-4xl font-bold">Free SAP Integration Courses</h1>
    <p class="text-xl text-gray-600">Get lifetime free access to our foundational courses with no payment or card required.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Course 1 -->
      <div class="border-l-4 border-green-500 p-6 bg-green-50 rounded">
        <h2 class="text-2xl font-bold mb-2">SAP BTP Basics</h2>
        <p class="text-gray-700 mb-4">Introductory course covering SAP Business Technology Platform fundamentals, tools, and services for beginners.</p>
        <div class="space-y-2 mb-4">
          <p class="text-sm text-gray-600"><strong>Duration:</strong> Self-paced</p>
          <p class="text-sm text-gray-600"><strong>Access:</strong> Lifetime free</p>
          <p class="text-sm text-gray-600"><strong>Requirements:</strong> None</p>
        </div>
        <a href="https://srini.pro/go/sap-btp-basics" class="bg-orange-500 text-white px-4 py-2 rounded font-semibold hover:bg-orange-600 transition inline-block">Enroll Now</a>
      </div>

      <!-- Course 2 -->
      <div class="border-l-4 border-green-500 p-6 bg-green-50 rounded">
        <h2 class="text-2xl font-bold mb-2">SAP Integration Suite Basics</h2>
        <p class="text-gray-700 mb-4">Foundational course providing overview of SAP BTP, CPI, and Cloud Integration Suite components for newcomers.</p>
        <div class="space-y-2 mb-4">
          <p class="text-sm text-gray-600"><strong>Duration:</strong> Self-paced</p>
          <p class="text-sm text-gray-600"><strong>Access:</strong> Lifetime free</p>
          <p class="text-sm text-gray-600"><strong>Requirements:</strong> None</p>
        </div>
        <a href="https://srini.pro/go/sap-integration-suite-basics" class="bg-orange-500 text-white px-4 py-2 rounded font-semibold hover:bg-orange-600 transition inline-block">Enroll Now</a>
      </div>

      <!-- Course 3 -->
      <div class="border-l-4 border-green-500 p-6 bg-green-50 rounded">
        <h2 class="text-2xl font-bold mb-2">Learn API, REST and JSON Basics</h2>
        <p class="text-gray-700 mb-4">Course addressing API, REST, and JSON concepts for interface development, covering modern web communication fundamentals.</p>
        <div class="space-y-2 mb-4">
          <p class="text-sm text-gray-600"><strong>Duration:</strong> Self-paced</p>
          <p class="text-sm text-gray-600"><strong>Access:</strong> Lifetime free</p>
          <p class="text-sm text-gray-600"><strong>Requirements:</strong> None</p>
        </div>
        <a href="https://srini.pro/go/learn-api-rest-json-basics" class="bg-orange-500 text-white px-4 py-2 rounded font-semibold hover:bg-orange-600 transition inline-block">Enroll Now</a>
      </div>

      <!-- Course 4 -->
      <div class="border-l-4 border-green-500 p-6 bg-green-50 rounded">
        <h2 class="text-2xl font-bold mb-2">Learn Cloud Computing</h2>
        <p class="text-gray-700 mb-4">Course explaining cloud computing terminology, deployment models (IaaS, PaaS, SaaS), and SAP cloud applications.</p>
        <div class="space-y-2 mb-4">
          <p class="text-sm text-gray-600"><strong>Duration:</strong> Self-paced</p>
          <p class="text-sm text-gray-600"><strong>Access:</strong> Lifetime free</p>
          <p class="text-sm text-gray-600"><strong>Requirements:</strong> None</p>
        </div>
        <a href="https://srini.pro/go/learn-cloud-computing" class="bg-orange-500 text-white px-4 py-2 rounded font-semibold hover:bg-orange-600 transition inline-block">Enroll Now</a>
      </div>

      <!-- Course 5 -->
      <div class="border-l-4 border-yellow-500 p-6 bg-yellow-50 rounded">
        <h2 class="text-2xl font-bold mb-2">SAP AI Basics</h2>
        <p class="text-gray-700 mb-4">Beginner-friendly course on SAP AI fundamentals, business AI services, and AI's impact on applications.</p>
        <div class="space-y-2 mb-4">
          <p class="text-sm text-gray-600"><strong>Duration:</strong> Self-paced</p>
          <p class="text-sm text-gray-600"><strong>Access:</strong> Lifetime free</p>
          <p class="text-sm text-yellow-700 font-semibold"><strong>Status:</strong> Coming Soon</p>
        </div>
        <button disabled class="bg-gray-300 text-gray-600 px-4 py-2 rounded font-semibold cursor-not-allowed">Coming Soon</button>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-blue-600 text-white p-8 rounded-lg text-center">
      <h2 class="text-2xl font-bold mb-4">Ready for Advanced Learning?</h2>
      <p class="mb-6">Explore our comprehensive mastery courses for in-depth SAP integration training.</p>
      <a href="/mastery-courses" class="bg-white text-orange-600 px-6 py-2 rounded font-semibold hover:bg-gray-100 transition inline-block">View Mastery Courses</a>
    </div>
  </div>
</BaseLayout>
