---
interface Props {
  course: { videoEmbed: string; };
}
const { course } = Astro.props;
---

<section id="proof">
  <div class="wrap">
    <div class="section-head">
      <span class="mono-tag">See it before you buy</span>
      <h2>A real look inside the PDFs — no fluff, just proof</h2>
      <p>60 seconds is enough to see the formatting, the depth of the answers, and exactly what lands in your account the moment you buy.</p>
    </div>
    <div class="video-frame">
      <div class="video-ratio">
        <iframe src={course.videoEmbed} title="SAP Integration Suite Interview Mastery Kit — inside look" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  #proof { padding: 72px 0; }
  .video-frame { max-width: 840px; margin: 0 auto; border-radius: 16px; overflow: hidden; box-shadow: 0 20px 50px rgba(10, 27, 51, 0.18); border: 1px solid var(--line); }
  .video-ratio { position: relative; width: 100%; padding-top: 56.25%; background: var(--ink); }
  .video-ratio iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  
  @media (max-width: 920px) {
    #proof { padding: 56px 0; }
  }
  
  @media (max-width: 520px) {
    .video-frame { border-radius: 12px; }
  }
</style>
