---
import SalesPageLayout from '../../layouts/SalesPageLayout.astro';
import cpiInterviewData from '../../data/courses/cpi-interview.json';

export async function getStaticPaths() {
  return [
    {
      params: { course: 'cpi-interview' },
      props: { courseData: cpiInterviewData }
    }
  ];
}

interface Props {
  courseData: any;
}

const { courseData } = Astro.props;
---

<SalesPageLayout course={courseData} />
