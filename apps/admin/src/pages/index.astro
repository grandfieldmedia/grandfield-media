---
export const prerender = false;
import AdminLayout from '../layouts/AdminLayout.astro';
import { formatPrice } from '@grandfield/shared-backend';
import { getStats, getOrders, getSiteIds, type OrderFilters } from '../lib/db';

const params = Astro.url.searchParams;
const filters: OrderFilters = {
  siteId: params.get('site') ?? undefined,
  from: params.get('from') ?? undefined,
  to: params.get('to') ?? undefined,
};

const [stats, recent, sites] = await Promise.all([
  getStats(filters),
  getOrders(filters, 8),
  getSiteIds(),
]);

const cards = [
  { label: 'Revenue', value: formatPrice(stats.revenueCents) },
  { label: 'Orders', value: String(stats.total) },
  { label: 'Completed', value: String(stats.completed) },
  { label: 'Refund rate', value: `${(stats.refundRate * 100).toFixed(1)}%` },
];
---

<AdminLayout title="Dashboard">
  <!-- Filters -->
  <form method="GET" class="mb-6 flex flex-wrap items-end gap-3">
    <div>
      <label class="block text-xs font-medium text-slate-500">Niche</label>
      <select name="site" class="mt-1 rounded-lg border border-slate-300 px-3 py-2 text-sm">
        <option value="">All niches</option>
        {sites.map((s) => <option value={s} selected={filters.siteId === s}>{s}</option>)}
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500">From</label>
      <input type="date" name="from" value={filters.from} class="mt-1 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500">To</label>
      <input type="date" name="to" value={filters.to} class="mt-1 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
    </div>
    <button class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary-light">Apply</button>
  </form>

  <!-- Stat cards -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {cards.map((c) => (
      <div class="rounded-xl bg-white p-6 shadow-sm">
        <div class="text-sm text-slate-500">{c.label}</div>
        <div class="mt-2 text-2xl font-bold text-primary">{c.value}</div>
      </div>
    ))}
  </div>

  <!-- Recent activity -->
  <div class="mt-8 rounded-xl bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-100 px-6 py-4">
      <h2 class="font-semibold text-primary">Recent orders</h2>
      <a href="/orders" class="text-sm font-medium text-accent hover:underline">View all &rarr;</a>
    </div>
    {recent.length === 0 ? (
      <p class="px-6 py-10 text-center text-sm text-slate-500">No orders yet.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="text-left text-xs uppercase text-slate-400">
          <tr>
            <th class="px-6 py-3 font-medium">Email</th>
            <th class="px-6 py-3 font-medium">Niche</th>
            <th class="px-6 py-3 font-medium">Amount</th>
            <th class="px-6 py-3 font-medium">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {recent.map((o) => (
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-3"><a href={`/orders/${o.id}`} class="text-accent hover:underline">{o.email}</a></td>
              <td class="px-6 py-3 text-slate-600">{o.site_id}</td>
              <td class="px-6 py-3">{formatPrice(o.amount)}</td>
              <td class="px-6 py-3 text-slate-600">{o.status}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
