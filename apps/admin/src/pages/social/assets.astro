---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAssets, getBrands } from '../../lib/social';

const [assets, brands] = await Promise.all([getAssets(), getBrands()]);
const brandName = (id: string) => brands.find((b) => b.id === id)?.name ?? '—';

function price(cents: number | null) {
  return cents == null ? '—' : `$${(cents / 100).toFixed(2)}`;
}
---

<AdminLayout title="Social — Assets">
  <div class="mb-6 flex items-center justify-between">
    <a href="/social" class="text-sm font-medium text-accent hover:underline">&larr; Back to Social</a>
  </div>

  <div class="mb-6 max-w-2xl rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
    <strong>Products live in the Google Sheet.</strong> Run 1 &amp; Run 2 promote from the
    <em>Grandfield Media — Assets</em> sheet (the <code>Assets</code> tab) — that's the source of truth.
    Add, edit, and switch products <strong>ON/OFF there</strong>. This page is a separate database
    registry and is <strong>not</strong> wired to the automation, so anything added below won't post.
  </div>

  <!-- Add asset -->
  <form method="POST" action="/api/social/assets" class="mb-8 rounded-xl bg-white p-5 shadow-sm">
    <input type="hidden" name="action" value="create" />
    <h2 class="mb-4 text-sm font-semibold text-primary">Add a product</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <label class="block text-xs font-medium text-slate-500">Brand *</label>
        <select name="brand_id" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
          {brands.map((b) => <option value={b.id}>{b.name}</option>)}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500">Name *</label>
        <input name="name" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="SAP CPI Masterclass" />
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500">Type</label>
        <input name="asset_type" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="course / ebook / template" />
      </div>
      <div class="lg:col-span-2">
        <label class="block text-xs font-medium text-slate-500">URL (the destination)</label>
        <input name="url" type="url" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="https://srini.pro/courses/cpi" />
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-500">Price (USD)</label>
        <input name="price" type="number" step="0.01" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="49" />
      </div>
      <div class="lg:col-span-3">
        <label class="block text-xs font-medium text-slate-500">Description (2–4 sentences — what it is & who it's for)</label>
        <textarea name="description" rows="2" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="A hands-on SAP CPI course covering..."></textarea>
      </div>
    </div>
    <div class="mt-4">
      <button class="rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-light">Add product</button>
    </div>
  </form>

  <!-- Asset list -->
  <div class="rounded-xl bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-3">
      <h2 class="text-sm font-semibold text-primary">Products</h2>
    </div>
    {assets.length === 0 ? (
      <p class="px-5 py-10 text-center text-sm text-slate-500">No products yet — add one above.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="text-left text-xs uppercase text-slate-400">
          <tr>
            <th class="px-5 py-2 font-medium">Brand</th>
            <th class="px-5 py-2 font-medium">Product</th>
            <th class="px-5 py-2 font-medium">Type</th>
            <th class="px-5 py-2 font-medium">Price</th>
            <th class="px-5 py-2 font-medium">Promote</th>
            <th class="px-5 py-2 font-medium text-right">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {assets.map((a) => (
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-3 text-slate-600">{brandName(a.brand_id)}</td>
              <td class="px-5 py-3">
                <div class="font-medium text-primary">{a.name}</div>
                {a.url && <a href={a.url} target="_blank" rel="noopener" class="text-xs text-accent hover:underline">{a.url}</a>}
              </td>
              <td class="px-5 py-3 text-slate-500">{a.asset_type ?? '—'}</td>
              <td class="px-5 py-3 text-slate-600">{price(a.price_cents)}</td>
              <td class="px-5 py-3">
                <span class={`rounded-full px-2.5 py-0.5 text-xs font-medium ${a.status === 'live' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500'}`}>
                  {a.status === 'live' ? 'ON' : 'OFF'}
                </span>
              </td>
              <td class="px-5 py-3 text-right">
                <form method="POST" action="/api/social/assets" class="inline">
                  <input type="hidden" name="action" value="toggle" />
                  <input type="hidden" name="id" value={a.id} />
                  <input type="hidden" name="status" value={a.status === 'live' ? 'paused' : 'live'} />
                  <button class={`rounded-lg px-4 py-1.5 text-xs font-semibold ${a.status === 'live' ? 'bg-red-50 text-red-700 hover:bg-red-100' : 'bg-green-50 text-green-700 hover:bg-green-100'}`}>
                    {a.status === 'live' ? 'Pause' : 'Promote'}
                  </button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
