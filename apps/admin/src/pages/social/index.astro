---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getPosts, getBrands, getSocialStats, getBrandSummary, getPostLog, getHealth, type PostFilters } from '../../lib/social';

const params = Astro.url.searchParams;
const filters: PostFilters = {
  brandId: params.get('brand') ?? undefined,
  lane: params.get('lane') ?? undefined,
  status: params.get('status') ?? undefined,
};

const LIMIT = 50;
const [posts, brands, stats, brandSummary, postLog, health] = await Promise.all([
  getPosts(filters, LIMIT),
  getBrands(),
  getSocialStats(filters),
  getBrandSummary(),
  getPostLog(),
  getHealth(),
]);

const healthColor: Record<string, string> = {
  ok: 'bg-green-100 text-green-700',
  warn: 'bg-amber-100 text-amber-700',
  broken: 'bg-red-100 text-red-700',
};

const brandName = (id: string) => brands.find((b) => b.id === id)?.name ?? '—';

// Did each content_item actually go to LinkedIn? post_log tells us (published vs draft).
const pubMap = new Map(postLog.map((pl) => [pl.content_item_id, pl.status]));
function pubState(p: { id: string; status: string }) {
  const s = pubMap.get(p.id);
  if (s === 'published') return { label: 'Published', cls: 'bg-green-100 text-green-700' };
  if (s === 'draft') return { label: 'Draft', cls: 'bg-amber-100 text-amber-700' };
  if (p.status === 'qa_failed') return { label: 'Blocked', cls: 'bg-red-100 text-red-700' };
  return { label: 'Not sent', cls: 'bg-slate-100 text-slate-500' };
}

const laneLabel: Record<string, string> = {
  run1_assets: 'Assets',
  run2_promotions: 'Promotion',
  run3_custom: 'Custom',
  run4_entertainer: 'Entertainer',
};
const lanes = Object.keys(laneLabel);
const statuses = ['planned', 'generated', 'qa_passed', 'qa_failed', 'scheduled', 'published', 'failed'];

const statusColor: Record<string, string> = {
  published: 'bg-green-100 text-green-700',
  qa_passed: 'bg-blue-100 text-blue-700',
  qa_failed: 'bg-red-100 text-red-700',
  planned: 'bg-slate-100 text-slate-600',
  generated: 'bg-amber-100 text-amber-700',
  scheduled: 'bg-indigo-100 text-indigo-700',
  failed: 'bg-red-100 text-red-700',
};

function fmtDate(iso: string) {
  return new Date(iso).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });
}
function fmtRel(iso: string | null) {
  if (!iso) return 'never';
  const diff = Date.now() - new Date(iso).getTime();
  const h = Math.floor(diff / 3.6e6);
  if (h < 1) return 'just now';
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}
const firstText = (p: { copy_by_platform: Record<string, string> | null }) =>
  Object.values(p.copy_by_platform ?? {})[0] ?? '';
const snippet = (p: { copy_by_platform: Record<string, string> | null }) =>
  firstText(p).split('\n')[0].slice(0, 90);

const cards = [
  { label: 'Total posts', value: String(stats.total) },
  { label: 'Posted today', value: String(stats.today) },
  { label: 'QA passed', value: String(stats.qaPassed) },
  { label: 'QA failed', value: String(stats.qaFailed) },
];
---

<AdminLayout title="Social">
  <div class="mb-4 flex justify-end gap-2">
    <a href="/social/assets" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">📦 Assets</a>
    <a href="/social/controls" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">⚙ Controls</a>
  </div>

  <!-- Filters (generic — lists whatever brands / lanes exist) -->
  <form method="GET" class="mb-6 flex flex-wrap items-end gap-3">
    <div>
      <label class="block text-xs font-medium text-slate-500">Brand</label>
      <select name="brand" class="mt-1 rounded-lg border border-slate-300 px-3 py-2 text-sm">
        <option value="">All brands</option>
        {brands.map((b) => <option value={b.id} selected={filters.brandId === b.id}>{b.name}</option>)}
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500">Lane</label>
      <select name="lane" class="mt-1 rounded-lg border border-slate-300 px-3 py-2 text-sm">
        <option value="">All lanes</option>
        {lanes.map((l) => <option value={l} selected={filters.lane === l}>{laneLabel[l]}</option>)}
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500">Status</label>
      <select name="status" class="mt-1 rounded-lg border border-slate-300 px-3 py-2 text-sm">
        <option value="">Any</option>
        {statuses.map((s) => <option value={s} selected={filters.status === s}>{s}</option>)}
      </select>
    </div>
    <button class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary-light">Filter</button>
  </form>

  <!-- Stat cards -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {cards.map((c) => (
      <div class="rounded-xl bg-white p-6 shadow-sm">
        <div class="text-sm text-slate-500">{c.label}</div>
        <div class="mt-2 text-2xl font-bold text-primary">{c.value}</div>
      </div>
    ))}
  </div>

  <!-- Health (Run 5 heartbeat) -->
  {health.length > 0 && (
    <div class="mt-8 rounded-xl bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-3">
        <h2 class="text-sm font-semibold text-primary">Health</h2>
      </div>
      <div class="flex flex-wrap gap-3 px-5 py-4">
        {health.map((h) => (
          <div class="flex items-center gap-2 rounded-lg border border-slate-100 px-3 py-2">
            <span class={`h-2 w-2 rounded-full ${h.status === 'ok' ? 'bg-green-500' : h.status === 'warn' ? 'bg-amber-500' : 'bg-red-500'}`}></span>
            <span class="text-sm font-medium text-slate-700">{h.component}</span>
            <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${healthColor[h.status] ?? 'bg-slate-100 text-slate-600'}`}>{h.status}</span>
            {h.detail && <span class="text-xs text-slate-400">{h.detail}</span>}
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Per-brand summary (all brands, always) -->
  <div class="mt-8 rounded-xl bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-3">
      <h2 class="text-sm font-semibold text-primary">Brands</h2>
    </div>
    {brandSummary.length === 0 ? (
      <p class="px-5 py-8 text-center text-sm text-slate-500">No brands yet.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="text-left text-xs uppercase text-slate-400">
          <tr>
            <th class="px-5 py-2 font-medium">Brand</th>
            <th class="px-5 py-2 font-medium">Niche</th>
            <th class="px-5 py-2 font-medium">Posts</th>
            <th class="px-5 py-2 font-medium">QA passed</th>
            <th class="px-5 py-2 font-medium">Last post</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {brandSummary.map((b) => (
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-2">
                <a href={`/social?brand=${b.id}`} class="font-medium text-accent hover:underline">{b.name}</a>
              </td>
              <td class="px-5 py-2 text-slate-500">{b.niche ?? '—'}</td>
              <td class="px-5 py-2 text-slate-700">{b.total}</td>
              <td class="px-5 py-2 text-slate-700">{b.qaPassed}</td>
              <td class="px-5 py-2 text-slate-500">{fmtRel(b.lastAt)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- Compact post log — one row each, click to expand -->
  <div class="mt-8 rounded-xl bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-100 px-5 py-3">
      <h2 class="text-sm font-semibold text-primary">Posts</h2>
      <span class="text-xs text-slate-400">Showing {posts.length}{posts.length === LIMIT ? ` (most recent ${LIMIT})` : ''}</span>
    </div>
    {posts.length === 0 ? (
      <p class="px-5 py-12 text-center text-sm text-slate-500">No posts match these filters.</p>
    ) : (
      <div class="divide-y divide-slate-100">
        {posts.map((p) => (
          <details class="group">
            <summary class="flex cursor-pointer list-none flex-wrap items-center gap-2 px-5 py-3 text-xs hover:bg-slate-50">
              <span class="text-slate-300 transition group-open:rotate-90">&#9656;</span>
              <span class="font-semibold text-primary">{brandName(p.brand_id)}</span>
              <span class="rounded-full bg-slate-100 px-2 py-0.5 text-slate-600">{laneLabel[p.lane ?? ''] ?? p.lane ?? '—'}</span>
              <span class={`rounded-full px-2 py-0.5 ${statusColor[p.status] ?? 'bg-slate-100 text-slate-600'}`}>{p.status}</span>
              <span class={`rounded-full px-2 py-0.5 font-medium ${pubState(p).cls}`}>{pubState(p).label}</span>
              {p.topic && <span class="font-medium text-slate-600">{p.topic}</span>}
              <span class="hidden max-w-sm truncate text-slate-400 md:inline">— {snippet(p)}</span>
              <span class="ml-auto whitespace-nowrap text-slate-400">{fmtDate(p.created_at)}</span>
            </summary>
            <p class="whitespace-pre-line border-t border-slate-50 bg-slate-50/50 px-5 py-4 text-sm leading-relaxed text-slate-800">
              {firstText(p) || '(no content)'}
            </p>
          </details>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
