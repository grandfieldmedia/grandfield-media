---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { formatPrice } from '@grandfield/shared-backend';
import { getOrderById } from '../../lib/db';

const { id } = Astro.params;
const order = id ? await getOrderById(id) : null;

if (!order) {
  return new Response('Order not found', { status: 404 });
}

const params = Astro.url.searchParams;
const flash = params.get('flash');
const flashMsg = params.get('msg');

function fmtDate(iso: string | null) {
  return iso ? new Date(iso).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) : '—';
}

const rows: [string, string][] = [
  ['Email', order.email],
  ['Niche (site_id)', order.site_id],
  ['Amount', formatPrice(order.amount)],
  ['Status', order.status],
  ['Stripe session', order.stripe_session_id ?? '—'],
  ['Downloaded', order.downloaded ? `Yes (${fmtDate(order.downloaded_at)})` : 'No'],
  ['Created', fmtDate(order.created_at)],
  ['Expires', fmtDate(order.expires_at)],
  ['Refund status', order.refund_status ?? '—'],
];
---

<AdminLayout title="Order detail">
  <a href="/orders" class="text-sm font-medium text-accent hover:underline">&larr; All orders</a>

  {flash && (
    <p class:list={['mt-4 rounded-md px-3 py-2 text-sm', flash === 'ok' ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700']}>
      {flashMsg}
    </p>
  )}

  <div class="mt-4 max-w-2xl rounded-xl bg-white p-6 shadow-sm">
    <dl class="divide-y divide-slate-100">
      {rows.map(([k, v]) => (
        <div class="flex justify-between gap-4 py-3">
          <dt class="text-sm text-slate-500">{k}</dt>
          <dd class="text-sm font-medium text-slate-900">{v}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-6 flex flex-wrap gap-3 border-t border-slate-100 pt-6">
      <form method="POST" action={`/api/orders/${order.id}/resend`}>
        <button class="rounded-lg border border-primary px-4 py-2 text-sm font-semibold text-primary hover:bg-primary hover:text-white">
          Resend download email
        </button>
      </form>
      <form method="POST" action={`/api/orders/${order.id}/refund`}
        onsubmit="return confirm('Refund this order via Stripe? This cannot be undone.');">
        <button
          disabled={order.status !== 'completed'}
          class="rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700 disabled:cursor-not-allowed disabled:opacity-40">
          Refund
        </button>
      </form>
    </div>
    <p class="mt-3 text-xs text-slate-400">Refunds require Stripe keys to be configured.</p>
  </div>
</AdminLayout>
