---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDashboard, getIdeas } from '../../lib/factory';

const params = Astro.url.searchParams;
const q = params.get('q')?.trim() ?? '';

const [dash, searchIdeas] = await Promise.all([
  getDashboard(),
  q ? getIdeas({ q }) : Promise.resolve([]),
]);
const searchBooks = q
  ? dash.books.filter((b) =>
      [b.chosen_title, b.title_suggestion, b.topic, b.niche_name]
        .some((v) => v?.toLowerCase().includes(q.toLowerCase())))
  : [];

const statusColor: Record<string, string> = {
  draft: 'bg-slate-100 text-slate-600', ready: 'bg-green-100 text-green-700',
  failed: 'bg-red-100 text-red-700',
};
const money = (n: number) => `$${n.toFixed(2)}`;
const title = (b: { chosen_title: string | null; title_suggestion: string | null; topic: string | null }) =>
  b.chosen_title || b.title_suggestion || b.topic || '(untitled)';
function fmtRel(iso: string) {
  const h = Math.floor((Date.now() - new Date(iso).getTime()) / 3.6e6);
  return h < 1 ? 'just now' : h < 24 ? `${h}h ago` : `${Math.floor(h / 24)}d ago`;
}

const cards = [
  { label: 'Books total', value: String(dash.books.length) },
  { label: 'In production', value: String(dash.inFlight.length) },
  { label: 'Published', value: String(dash.catalog.length) },
  { label: 'Total spend', value: money(dash.totalSpendUsd) },
];
---

<AdminLayout title="🏭 KDPFactory — Dashboard">
  <div class="mb-4 flex flex-wrap justify-end gap-2">
    <a href="/kdp" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">💡 Workbench</a>
    <a href="/kdp/prompts" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">✍️ Prompts</a>
    <a href="/kdp/references" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">📚 References</a>
    <a href="/kdp/niche-defaults" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">⚙ Niche Defaults</a>
  </div>

  <!-- Stat cards -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {cards.map((c) => (
      <div class="rounded-xl bg-white p-6 shadow-sm">
        <div class="text-sm text-slate-500">{c.label}</div>
        <div class="mt-2 text-2xl font-bold text-primary">{c.value}</div>
      </div>
    ))}
  </div>

  <!-- Search (before-you-design check) -->
  <form method="GET" class="mt-8 flex items-end gap-3">
    <div class="flex-1">
      <label class="block text-xs font-medium text-slate-500">Search ideas + books ("did we already make this?")</label>
      <input name="q" value={q} class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="e.g. finance for mom" />
    </div>
    <button class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary-light">Search</button>
  </form>
  {q && (
    <div class="mt-3 rounded-xl bg-white p-4 shadow-sm text-sm">
      <p class="mb-2 font-semibold text-primary">{searchIdeas.length + searchBooks.length} match{searchIdeas.length + searchBooks.length === 1 ? '' : 'es'} for "{q}"</p>
      {searchIdeas.map((i) => <div><a href={`/kdp/${i.id}`} class="text-accent hover:underline">💡 {i.working_title || i.topic}</a> <span class="text-slate-400">— {i.niche_name}</span></div>)}
      {searchBooks.map((b) => <div><a href={`/kdp/book/${b.id}`} class="text-accent hover:underline">📖 {title(b)}</a> <span class="text-slate-400">— {b.niche_name}</span></div>)}
      {searchIdeas.length + searchBooks.length === 0 && <p class="text-slate-400">Nothing yet — clear to design something new.</p>}
    </div>
  )}

  <!-- Pipeline lens -->
  <div class="mt-8 rounded-xl bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-3"><h2 class="text-sm font-semibold text-primary">Pipeline</h2></div>
    {dash.failed.length > 0 && (
      <div class="border-b border-red-100 bg-red-50/50 px-5 py-3 text-sm text-red-700">
        <strong>{dash.failed.length} failed</strong> — need attention:
        {dash.failed.map((b) => <a href={`/kdp/book/${b.id}`} class="ml-2 underline">{title(b)}</a>)}
      </div>
    )}
    {dash.inFlight.length === 0 && dash.failed.length === 0 ? (
      <p class="px-5 py-8 text-center text-sm text-slate-500">Nothing in production. Approve an idea to start a book.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="text-left text-xs uppercase text-slate-400"><tr>
          <th class="px-5 py-2 font-medium">Book</th><th class="px-5 py-2 font-medium">Niche</th>
          <th class="px-5 py-2 font-medium">Run</th><th class="px-5 py-2 font-medium">Step</th>
          <th class="px-5 py-2 font-medium">Status</th>
        </tr></thead>
        <tbody class="divide-y divide-slate-100">
          {dash.inFlight.map((b) => (
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-2"><a href={`/kdp/book/${b.id}`} class="font-medium text-accent hover:underline">{title(b)}</a></td>
              <td class="px-5 py-2 text-slate-500">{b.niche_name ?? '—'}</td>
              <td class="px-5 py-2 text-slate-500">{b.run_type}</td>
              <td class="px-5 py-2 text-slate-500">{b.current_step ?? '—'}</td>
              <td class="px-5 py-2"><span class={`rounded-full px-2 py-0.5 text-xs ${statusColor[b.status] ?? 'bg-amber-100 text-amber-700'}`}>{b.status}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- Catalog lens -->
  <div class="mt-8 rounded-xl bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-3"><h2 class="text-sm font-semibold text-primary">Catalog</h2></div>
    {dash.catalog.length === 0 ? (
      <p class="px-5 py-8 text-center text-sm text-slate-500">No finished books yet.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="text-left text-xs uppercase text-slate-400"><tr>
          <th class="px-5 py-2 font-medium">Title</th><th class="px-5 py-2 font-medium">Niche</th>
          <th class="px-5 py-2 font-medium">Ver</th><th class="px-5 py-2 font-medium">Cost</th>
          <th class="px-5 py-2 font-medium">Links</th>
        </tr></thead>
        <tbody class="divide-y divide-slate-100">
          {dash.catalog.map((b) => (
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-2"><a href={`/kdp/book/${b.id}`} class="font-medium text-accent hover:underline">{title(b)}</a></td>
              <td class="px-5 py-2 text-slate-500">{b.niche_name ?? '—'}</td>
              <td class="px-5 py-2 text-slate-500">v{b.version}</td>
              <td class="px-5 py-2 text-slate-700">{money(dash.spendByBook[b.id] ?? 0)}</td>
              <td class="px-5 py-2 space-x-2">
                {b.master_doc_url && <a href={b.master_doc_url} target="_blank" rel="noopener" class="text-xs text-accent hover:underline">Doc</a>}
                {b.kdp_url && <a href={b.kdp_url} target="_blank" rel="noopener" class="text-xs text-accent hover:underline">KDP</a>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- Money lens -->
  <div class="mt-8 rounded-xl bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-3"><h2 class="text-sm font-semibold text-primary">Money</h2></div>
    <div class="px-5 py-4 text-sm">
      <p class="text-slate-700">Total production spend: <strong>{money(dash.totalSpendUsd)}</strong> across {dash.books.length} book{dash.books.length === 1 ? '' : 's'}.</p>
      <p class="mt-1 text-xs text-slate-400">Spend-vs-earn appears here once KDP sales reports are imported.</p>
    </div>
  </div>
</AdminLayout>
