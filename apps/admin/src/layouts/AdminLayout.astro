---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const email = Astro.locals.user?.email ?? '';
const path = Astro.url.pathname;
const nav = [
  { text: 'Dashboard', href: '/' },
  { text: 'Orders', href: '/orders' },
  { text: 'Social', href: '/social' },
];
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title} · Grandfield Admin</title>
  </head>
  <body class="min-h-screen bg-slate-100 font-sans text-slate-900">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="hidden w-60 shrink-0 flex-col bg-primary text-white md:flex">
        <div class="px-6 py-5 text-lg font-bold">Grandfield Admin</div>
        <nav class="flex flex-1 flex-col gap-1 px-3">
          {nav.map((n) => (
            <a
              href={n.href}
              class:list={[
                'rounded-md px-3 py-2 text-sm font-medium transition',
                isActive(n.href) ? 'bg-white/15 text-white' : 'text-slate-300 hover:bg-white/10',
              ]}
            >
              {n.text}
            </a>
          ))}
        </nav>
        <form method="POST" action="/api/auth/logout" class="border-t border-white/10 p-3">
          <p class="mb-2 px-2 text-xs text-slate-400">{email}</p>
          <button class="w-full rounded-md px-3 py-2 text-left text-sm text-slate-300 hover:bg-white/10">Sign out</button>
        </form>
      </aside>

      <!-- Main -->
      <div class="flex-1">
        <header class="flex items-center justify-between border-b border-slate-200 bg-white px-6 py-4">
          <h1 class="text-xl font-bold text-primary">{title}</h1>
          <span class="text-sm text-slate-500 md:hidden">{email}</span>
        </header>
        <main class="p-6">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
