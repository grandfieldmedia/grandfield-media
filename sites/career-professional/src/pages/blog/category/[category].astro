---
export const prerender = true;
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import BlogPostCard from '@grandfield/shared-ui/components/BlogPostCard.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((p) => !p.data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((label) => ({
    params: { category: label.toLowerCase() },
    props: {
      label,
      posts: posts
        .filter((p) => p.data.category === label)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { label, posts } = Astro.props;
---

<Layout title={`${label} articles`} description={`Money guides in the ${label} category.`}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <a href="/blog" class="text-sm font-medium text-accent hover:underline">&larr; All posts</a>
    <h1 class="mt-6 text-4xl font-bold text-primary">Category: {label}</h1>
    <div class="mt-10 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((p) => (
        <BlogPostCard
          title={p.data.title}
          description={p.data.description}
          href={`/blog/${p.id}`}
          pubDate={p.data.pubDate}
          category={p.data.category}
          image={p.data.image}
        />
      ))}
    </div>
  </section>
</Layout>
