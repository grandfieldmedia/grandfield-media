---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Features from '@grandfield/shared-ui/components/Features.astro';
import CallToAction from '@grandfield/shared-ui/components/CallToAction.astro';

const features = [
  { title: 'Recruiter-ready', description: 'Clean, ATS-friendly formats that pass screening and impress hiring managers.' },
  { title: 'No guesswork', description: 'Fill-in-the-blank templates and proven examples — you never start from a blank page.' },
  { title: 'Yours forever', description: 'One-time purchase, instant download, no subscriptions.' },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="bg-primary text-white">
    <div class="mx-auto max-w-6xl px-4 py-24 text-center sm:px-6 lg:px-8">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-accent">Grandfield Careers</p>
      <h1 class="mx-auto max-w-3xl text-4xl font-bold leading-tight sm:text-5xl">
        Land the job with resume and interview templates that actually work.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-200">
        Ready-to-use resume templates, interview prep kits, and career guides — professional, ATS-friendly, and built to get you hired faster.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/products" class="rounded-lg bg-accent px-8 py-3 font-semibold text-white transition hover:bg-accent-light">
          Browse Products
        </a>
        <a href="/blog" class="rounded-lg border border-white/30 px-8 py-3 font-semibold text-white transition hover:bg-white/10">
          Read the Blog
        </a>
      </div>
    </div>
  </section>

  <Features
    title="Everything you need to get hired"
    subtitle="Professional templates and prep tools designed to move you from applicant to offer."
    items={features}
  />

  <CallToAction
    title="Start your job search the right way"
    subtitle="Browse resume templates, interview prep kits, and career guides — instant download, yours to keep."
    actions={[
      { text: 'Browse Products', href: '/products' },
      { text: 'Read the Blog', href: '/blog', primary: false },
    ]}
  />
</Layout>
