---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import Prose from '@grandfield/shared-ui/components/Prose.astro';
const updated = 'July 10, 2026';
---

<Layout title="Privacy Policy" description="How Grandfield Events handles your data." noindex={true}>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-4xl font-bold text-primary">Privacy Policy</h1>
    <p class="mt-2 text-sm text-slate-500">Last updated: {updated}</p>
    <div class="mt-8">
      <Prose>
        <p><em>This is a starter template — have it reviewed before launch.</em></p>
        <h2>What we collect</h2>
        <p>When you buy a product, we collect your email address and payment
          confirmation (processed securely by our payment provider, Stripe). We do
          not store card details. We use privacy-friendly analytics to understand
          how the site is used.</p>
        <h2>How we use it</h2>
        <p>Your email is used to deliver your purchase and re-send your download
          link if you request it. We do not sell your data.</p>
        <h2>Analytics &amp; cookies</h2>
        <p>We use PostHog and advertising pixels to measure site performance and
          ad effectiveness. These may set cookies.</p>
        <h2>Contact</h2>
        <p>Questions? Email <a href="mailto:hello@grandfieldevents.com">hello@grandfieldevents.com</a>.</p>
      </Prose>
    </div>
  </section>
</Layout>
