---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resend download link" description="Lost your download link? Have it re-sent to your email." noindex={true}>
  <section class="mx-auto max-w-lg px-4 py-24 sm:px-6">
    <h1 class="text-3xl font-bold text-primary">Resend your download link</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">
      Enter the email you used at checkout and we'll re-send your most recent
      download link.
    </p>

    <form id="resend-form" class="mt-8 space-y-4">
      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Email address</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-2.5 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent dark:border-slate-700 dark:bg-slate-900"
          placeholder="you@example.com"
        />
      </div>
      <button type="submit" class="w-full rounded-lg bg-primary px-6 py-3 font-semibold text-white transition hover:bg-primary-light">
        Resend link
      </button>
      <p id="resend-msg" class="hidden text-sm"></p>
    </form>
  </section>
</Layout>

<script is:inline>
  (function () {
    var form = document.getElementById('resend-form');
    var msg = document.getElementById('resend-msg');
    if (!form) return;
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var email = form.email.value;
      msg.className = 'text-sm text-slate-500';
      msg.textContent = 'Sending…';
      msg.classList.remove('hidden');
      try {
        var res = await fetch('/api/resend-link', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });
        // Always show the same message so we don't reveal which emails exist.
        msg.className = 'text-sm text-green-600';
        msg.textContent = "If that email has a purchase, we've sent the link. Check your inbox.";
        form.reset();
      } catch (err) {
        msg.className = 'text-sm text-red-600';
        msg.textContent = 'Something went wrong. Please try again.';
      }
    });
  })();
</script>
