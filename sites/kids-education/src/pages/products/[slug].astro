---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import ProductSalesLayout from '@grandfield/shared-ui/layouts/ProductSalesLayout.astro';
import { getProductBySlug, toSummary } from '../../lib/products';

const { slug } = Astro.params;
const product = slug ? await getProductBySlug(slug) : null;

if (!product) {
  return new Response('Product not found', { status: 404 });
}

// Paddle price IDs per product slug. Public-safe (used in the browser by Paddle.js).
// TODO: move to a `paddle_price_id` column on the products table as the catalog grows.
const PADDLE_PRICE_IDS: Record<string, string> = {
  'abc-activity-coloring-pack': 'pri_01kxdvnv9kktwbttgt9vz3232n',
};
const priceId = PADDLE_PRICE_IDS[slug ?? ''] ?? '';

// Product hero/mockup images live in /public/images and are keyed by slug.
// Falls back to the DB `image` field (or the letter placeholder) when unset.
// TODO: move to a `paddle_price_id`/`image` column on products as the catalog grows.
const PRODUCT_IMAGES: Record<string, string> = {
  'abc-activity-coloring-pack': '/images/abc-activity-coloring-pack.png',
};
const summary = { ...toSummary(product), image: PRODUCT_IMAGES[slug ?? ''] ?? toSummary(product).image };
// Read at RUNTIME from process.env (Vercel injects it there) — not import.meta.env,
// which Vite would inline at build time as undefined if the var wasn't in the build.
const clientToken = process.env.PADDLE_CLIENT_TOKEN ?? '';
// Environment is derived from the token: `test_…` = Paddle sandbox, `live_…` = production.
const isSandbox = clientToken.startsWith('test_');
const checkoutEnabled = !!clientToken && !!priceId;

// Generic benefits/FAQ for a printable kids pack (per-product content can move to
// a content collection later; kept here so the sales page is complete now).
const benefits = [
  { title: 'Print & play', description: 'Print at home in seconds — no prep and no screens needed.' },
  { title: 'Age-appropriate', description: 'Designed for little learners with bright, simple, engaging activities.' },
  { title: 'Print again anytime', description: 'One-time purchase, instant download, reprint as often as you like.' },
];
const faqs = [
  { question: 'What format is it?', answer: 'A print-ready PDF you can download instantly after purchase.' },
  { question: 'Do I need special software?', answer: 'No — any PDF reader and a home printer work.' },
  { question: 'What ages is it for?', answer: 'Our packs are designed for ages 3–10; check each product for its age range.' },
  { question: 'Can I get a refund?', answer: 'See our refund policy — contact us within 14 days if it isn’t as described.' },
];
---

<Layout title={product.name} description={product.description ?? 'A Grandfield Kids printable download.'} ogType="product">
  {isSandbox && checkoutEnabled && (
    <div class="bg-yellow-100 px-4 py-3 text-center text-sm font-medium text-yellow-800">
      🧪 Paddle Sandbox — this is a test checkout. No real charges will occur.
    </div>
  )}
  <ProductSalesLayout
    product={summary}
    benefits={benefits}
    faqs={faqs}
    checkoutEnabled={checkoutEnabled}
    priceNote="One-time purchase. Taxes may apply and will be calculated at checkout."
  />

  {checkoutEnabled && (
    <Fragment>
      <script src="https://cdn.paddle.com/paddle/v2/paddle.js" is:inline></script>
      <script is:inline define:vars={{ clientToken, isSandbox, priceId }}>
        (function () {
          function ready(fn) {
            if (document.readyState !== 'loading') fn();
            else document.addEventListener('DOMContentLoaded', fn);
          }
          function whenPaddle(cb, tries) {
            tries = tries || 0;
            if (window.Paddle) return cb();
            if (tries > 60) return; // ~12s then give up
            setTimeout(function () { whenPaddle(cb, tries + 1); }, 200);
          }
          ready(function () {
            whenPaddle(function () {
              if (isSandbox) window.Paddle.Environment.set('sandbox');
              window.Paddle.Initialize({ token: clientToken });
              // The shared sales layout renders form(s) posting to /api/checkout.
              // Intercept the submit and open Paddle's hosted overlay instead.
              document.querySelectorAll('form[action="/api/checkout"]').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                  e.preventDefault();
                  window.Paddle.Checkout.open({
                    items: [{ priceId: priceId, quantity: 1 }],
                    settings: { successUrl: window.location.origin + '/thank-you' },
                  });
                });
              });
            });
          });
        })();
      </script>
    </Fragment>
  )}
</Layout>
