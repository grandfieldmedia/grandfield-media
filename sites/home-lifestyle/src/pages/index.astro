---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Features from '@grandfield/shared-ui/components/Features.astro';
import CallToAction from '@grandfield/shared-ui/components/CallToAction.astro';
import { siteConfig } from '../site.config';

const features = [
  { title: 'Ready to use', description: 'Download, open, and start — no setup or learning curve.' },
  { title: 'Instant delivery', description: 'Get your files immediately after purchase.' },
  { title: 'Yours forever', description: 'One-time purchase, instant download, no subscriptions.' },
];
---

<Layout title="Home">
  <section class="bg-primary text-white">
    <div class="mx-auto max-w-6xl px-4 py-24 text-center sm:px-6 lg:px-8">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-accent">{siteConfig.brand}</p>
      <h1 class="mx-auto max-w-3xl text-4xl font-bold leading-tight sm:text-5xl">{siteConfig.tagline}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-200">{siteConfig.description}</p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/products" class="rounded-lg bg-accent px-8 py-3 font-semibold text-primary transition hover:bg-accent-light">Browse Products</a>
        <a href="/blog" class="rounded-lg border border-white/30 px-8 py-3 font-semibold text-white transition hover:bg-white/10">Read the Blog</a>
      </div>
    </div>
  </section>

  <Features title="Practical products, ready when you are" subtitle="Everything we make is designed to be useful the moment you download it." items={features} />

  <CallToAction title="Get started today" subtitle="Browse our products — instant download, yours to keep." actions={[{ text: 'Browse Products', href: '/products' }, { text: 'Read the Blog', href: '/blog', primary: false }]} />
</Layout>
