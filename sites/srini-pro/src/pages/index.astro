---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="Learn SAP Integration Tools" description="Learn SAP PO, SAP BTP, SAP CPI, and SAP AI with practical online courses from 20+ years of real-world experience.">
  <div class="space-y-12">
    <!-- Hero Section -->
    <section class="text-center space-y-6">
      <h1 class="text-5xl font-bold text-gray-900">Learn SAP Integration Tools</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Master SAP Integration with practical courses in SAP PO, SAP CPI, SAP BTP, SAP AI, and APIs. Learn from an SAP Integration Architect with 20+ years of experience.</p>
      <div class="flex justify-center gap-4">
        <a href="/free-courses" class="bg-orange-500 text-white px-8 py-3 rounded-lg font-semibold hover:bg-orange-600 transition">Start Free Courses</a>
        <a href="/mastery-courses" class="bg-gray-200 text-gray-900 px-8 py-3 rounded-lg font-semibold hover:bg-gray-300 transition">View Mastery</a>
      </div>
    </section>

    <!-- Main Course Offering -->
    <section class="bg-blue-50 p-8 rounded-lg">
      <h2 class="text-3xl font-bold mb-4">SAP PO Mastery Course</h2>
      <p class="text-gray-700 mb-6">Comprehensive training covering architecture, interface development, B2B/EDI adapters, REST integration, Java mapping, monitoring, and real-world projects.</p>
      <a href="/sap-po-course" class="text-blue-600 font-semibold hover:text-blue-700">Learn More →</a>
    </section>

    <!-- Free Courses Preview -->
    <section>
      <h2 class="text-3xl font-bold mb-8">Free Courses Available</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="border rounded-lg p-6 hover:shadow-lg transition">
          <h3 class="font-bold text-lg mb-2">SAP BTP Basics</h3>
          <p class="text-gray-600 mb-4">Introductory course covering SAP Business Technology Platform fundamentals.</p>
          <span class="text-green-600 font-semibold">Lifetime Free Access</span>
        </div>
        <div class="border rounded-lg p-6 hover:shadow-lg transition">
          <h3 class="font-bold text-lg mb-2">SAP Integration Suite Basics</h3>
          <p class="text-gray-600 mb-4">Foundational course providing overview of SAP BTP, CPI, and Cloud Integration Suite.</p>
          <span class="text-green-600 font-semibold">Lifetime Free Access</span>
        </div>
        <div class="border rounded-lg p-6 hover:shadow-lg transition">
          <h3 class="font-bold text-lg mb-2">API, REST & JSON Basics</h3>
          <p class="text-gray-600 mb-4">Course addressing API, REST, and JSON concepts for interface development.</p>
          <span class="text-green-600 font-semibold">Lifetime Free Access</span>
        </div>
      </div>
    </section>

    <!-- Instructor Profile -->
    <section class="bg-gray-50 p-8 rounded-lg">
      <h2 class="text-3xl font-bold mb-4">Meet Your Instructor</h2>
      <h3 class="text-2xl font-semibold text-blue-600 mb-2">Srinivas Vanamala</h3>
      <p class="text-gray-700 mb-4">SAP Integration Architect with 20+ years of experience</p>
      <p class="text-gray-700">Emphasizes "hands-on experience—not just theory" and focuses on real consulting skills and industry best practices.</p>
    </section>
  </div>
</BaseLayout>
