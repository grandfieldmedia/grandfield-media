---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="SAP PO Mastery Course" description="Learn SAP Process Orchestration from 20+ years of real-world experience. Complete curriculum from basics to advanced interface development.">
  <div class="space-y-12">
    <div class="space-y-4">
      <h1 class="text-4xl font-bold">SAP PO Mastery Course</h1>
      <p class="text-xl text-gray-600">Learn SAP Process Orchestration - This is the only course needed to master and become an SAP PO professional.</p>
    </div>

    <!-- Quick Info -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 bg-blue-50 p-8 rounded-lg">
      <div>
        <p class="text-sm text-gray-600 mb-1">Experience Required</p>
        <p class="text-lg font-bold">20+ Years</p>
      </div>
      <div>
        <p class="text-sm text-gray-600 mb-1">Learning Format</p>
        <p class="text-lg font-bold">Self-Paced</p>
      </div>
      <div>
        <p class="text-sm text-gray-600 mb-1">Access</p>
        <p class="text-lg font-bold">Lifetime</p>
      </div>
    </div>

    <!-- Course Description -->
    <section>
      <h2 class="text-2xl font-bold mb-4">Course Overview</h2>
      <p class="text-gray-700 mb-4">The program teaches enterprise integration through practical, project-based learning. Instruction is grounded in "20+ years of real-world SAP integration experience," with emphasis on production-ready techniques and industry best practices rather than theoretical concepts alone.</p>
      <p class="text-gray-700">This comprehensive course is designed to transform you from a learner into a confident SAP PO professional ready for real-world projects.</p>
    </section>

    <!-- 8 Core Modules -->
    <section>
      <h2 class="text-2xl font-bold mb-8">Curriculum - 8 Core Modules</h2>
      <div class="space-y-4">
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">1. SAP PO Basics</h3>
          <p class="text-gray-700">Foundation covering architecture, components, and navigation</p>
        </div>
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">2. Interface Development with Standard Adapters</h3>
          <p class="text-gray-700">File, SFTP, SOAP, REST, RFC, and JDBC configuration</p>
        </div>
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">3. Java Mapping Development</h3>
          <p class="text-gray-700">Custom mapping creation and debugging</p>
        </div>
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">4. Adapter Module Development</h3>
          <p class="text-gray-700">Custom extensions for advanced processing</p>
        </div>
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">5. B2B/EDI Interface Development</h3>
          <p class="text-gray-700">Enterprise trading partner communications</p>
        </div>
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">6. AS2 Adapter Interface Development</h3>
          <p class="text-gray-700">Secure AS2 communications with encryption</p>
        </div>
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">7. REST/API/JSON Interface Development</h3>
          <p class="text-gray-700">Modern API and JSON integrations</p>
        </div>
        <div class="border-l-4 border-blue-600 pl-6 py-4">
          <h3 class="font-bold text-lg mb-2">8. Monitoring and Interface Troubleshooting</h3>
          <p class="text-gray-700">Production support and issue resolution</p>
        </div>
      </div>
    </section>

    <!-- Additional Benefits -->
    <section class="bg-green-50 p-8 rounded-lg">
      <h2 class="text-2xl font-bold mb-6">What's Included</h2>
      <ul class="space-y-3">
        <li class="flex items-start gap-3">
          <span class="text-green-600 font-bold text-xl">✓</span>
          <span class="text-gray-700">Lifetime course access</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green-600 font-bold text-xl">✓</span>
          <span class="text-gray-700">Lifetime free updates</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green-600 font-bold text-xl">✓</span>
          <span class="text-gray-700">Q&A instructor support</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green-600 font-bold text-xl">✓</span>
          <span class="text-gray-700">Access to professional SAP PO resources</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green-600 font-bold text-xl">✓</span>
          <span class="text-gray-700">Real-world scenario-based training</span>
        </li>
      </ul>
    </section>

    <!-- Important Note -->
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded">
      <p class="text-gray-700"><strong>Note:</strong> No SAP system access is provided with enrollment. You can set up your own SAP learning environment or use the course with existing systems.</p>
    </div>

    <!-- CTA -->
    <div class="bg-blue-600 text-white p-8 rounded-lg text-center">
      <h2 class="text-2xl font-bold mb-4">Ready to Master SAP PO?</h2>
      <p class="mb-6">One-time payment. Lifetime access. Lifetime updates.</p>
      <a href="/sap-po-mastery" class="bg-white text-blue-600 px-8 py-3 rounded font-semibold hover:bg-gray-100 transition inline-block">Enroll Now</a>
    </div>
  </div>
</BaseLayout>
