---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="About Srini" description="Learn about Srinivas Vanamala, SAP Integration Architect with 20+ years of real-world experience in enterprise integration.">
  <div class="space-y-12">
    <h1 class="text-4xl font-bold">About Your Instructor</h1>

    <section class="space-y-6">
      <div class="bg-blue-50 p-8 rounded-lg">
        <h2 class="text-3xl font-bold text-blue-600 mb-2">Srinivas Vanamala</h2>
        <p class="text-lg text-gray-600 mb-4">SAP Integration Architect</p>
        <p class="text-gray-700">With more than 20 years of professional experience in SAP technologies and middleware solutions, Srinivas brings extensive hands-on knowledge across implementation, development, and operational aspects of integration projects.</p>
      </div>
    </section>

    <!-- Background -->
    <section>
      <h2 class="text-2xl font-bold mb-6">Professional Background</h2>
      <div class="space-y-4">
        <div>
          <h3 class="text-xl font-bold mb-2">20+ Years of SAP Integration Experience</h3>
          <p class="text-gray-700">Worked directly with SAP Integration platforms and enterprise systems, accumulating extensive expertise in production implementations.</p>
        </div>
        <div>
          <h3 class="text-xl font-bold mb-2">Enterprise Integration Specialist</h3>
          <p class="text-gray-700">Deep knowledge across implementation, development, and operational support for complex integration projects.</p>
        </div>
        <div>
          <h3 class="text-xl font-bold mb-2">Technology Focus</h3>
          <p class="text-gray-700">Specialization in:</p>
          <ul class="list-disc list-inside text-gray-700 mt-2 space-y-1">
            <li>SAP Process Orchestration (PO)</li>
            <li>SAP Business Technology Platform (BTP)</li>
            <li>SAP Integration Suite and Cloud Platform Integration (CPI)</li>
            <li>Enterprise integration architecture and patterns</li>
            <li>Real-world business scenario applications</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Mission & Philosophy -->
    <section class="bg-gray-50 p-8 rounded-lg">
      <h2 class="text-2xl font-bold mb-6">Mission & Teaching Philosophy</h2>
      <blockquote class="text-lg text-gray-700 italic border-l-4 border-blue-600 pl-6 mb-6">
        "Practical SAP Integration skills that can be applied immediately in real-world projects"
      </blockquote>
      
      <div class="space-y-4">
        <div>
          <h3 class="font-bold text-lg mb-2">Hands-On Experience, Not Just Theory</h3>
          <p class="text-gray-700">The platform delivers practical, job-ready competencies grounded in actual enterprise implementations rather than theoretical instruction.</p>
        </div>
        
        <div>
          <h3 class="font-bold text-lg mb-2">Accessible to All Levels</h3>
          <p class="text-gray-700">Courses are designed to be accessible to both beginners and experienced professionals, with structured lessons that deconstruct complex topics into understandable components.</p>
        </div>
        
        <div>
          <h3 class="font-bold text-lg mb-2">Real Consulting Skills</h3>
          <p class="text-gray-700">Focus on industry best practices and consulting methodologies applicable to live projects.</p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-2">Target Audience</h3>
          <p class="text-gray-700">Courses designed for consultants, developers, architects, and IT professionals seeking SAP integration expertise.</p>
        </div>
      </div>
    </section>

    <!-- What Students Learn -->
    <section>
      <h2 class="text-2xl font-bold mb-6">What You'll Learn From Srini</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-2xl">→</span>
          <div>
            <h3 class="font-bold mb-2">Production-Ready Techniques</h3>
            <p class="text-gray-700">Solutions and patterns actually used in enterprise environments</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-2xl">→</span>
          <div>
            <h3 class="font-bold mb-2">Real-World Project Skills</h3>
            <p class="text-gray-700">Practical capabilities directly applicable to your work</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-2xl">→</span>
          <div>
            <h3 class="font-bold mb-2">Interview Readiness</h3>
            <p class="text-gray-700">Knowledge and confidence needed for SAP integration roles</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-2xl">→</span>
          <div>
            <h3 class="font-bold mb-2">Career Advancement</h3>
            <p class="text-gray-700">Tools and expertise to advance as an SAP professional</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <div class="bg-blue-600 text-white p-8 rounded-lg text-center">
      <h2 class="text-2xl font-bold mb-4">Have Questions?</h2>
      <p class="mb-6">Get in touch with any questions about the courses or your learning journey.</p>
      <a href="mailto:contact@srini.pro" class="bg-white text-orange-600 px-8 py-3 rounded font-semibold hover:bg-gray-100 transition inline-block">Contact Srini</a>
    </div>
  </div>
</BaseLayout>
