---
import BaseLayout from '../layouts/base-layout.astro';
---

<BaseLayout title="Master SAP Integration" description="Comprehensive SAP PO and SAP CPI mastery courses built from 20+ years of experience. One-time payment with lifetime access.">
  <div class="space-y-12">
    <div class="text-center space-y-4">
      <h1 class="text-4xl font-bold">Master SAP Integration</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">Comprehensive SAP PO, SAP CPI, SAP BTP, and future Mastery courses built from 20+ years of experience.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- SAP PO Mastery -->
      <div class="border-2 border-blue-300 rounded-lg p-8 hover:shadow-lg transition">
        <div class="mb-4">
          <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-semibold">Available Now</span>
        </div>
        <h2 class="text-2xl font-bold mb-4">Complete SAP PO Mastery Course</h2>
        <p class="text-gray-700 mb-6">Learn SAP PO from start to finish with real-world examples, hands-on practice, and expert guidance. Develop practical capabilities, build professional confidence for live projects, support interview readiness, and advance your career as an SAP PO consultant.</p>
        
        <div class="space-y-3 mb-6 text-sm text-gray-600">
          <p><strong>Access:</strong> Lifetime</p>
          <p><strong>Updates:</strong> Free lifetime updates included</p>
          <p><strong>Cost:</strong> One-time payment</p>
        </div>
        
        <a href="/sap-po-mastery.html" class="bg-orange-500 text-white px-6 py-3 rounded font-semibold hover:bg-orange-600 transition inline-block">View Details & Enroll</a>
  
      </div>

      <!-- SAP CPI Mastery -->
      <div class="border-2 border-gray-300 rounded-lg p-8 hover:shadow-lg transition opacity-75">
        <div class="mb-4">
          <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-sm font-semibold">Coming Soon</span>
        </div>
        <h2 class="text-2xl font-bold mb-4">Complete SAP CPI Mastery Course</h2>
        <p class="text-gray-700 mb-6">Learn SAP CPI from start to finish with real-world examples, hands-on practice, and expert guidance. Designed to develop SAP CPI professional consultant skills for production environments.</p>
        
        <div class="space-y-3 mb-6 text-sm text-gray-600">
          <p><strong>Access:</strong> Lifetime</p>
          <p><strong>Updates:</strong> Free lifetime updates included</p>
          <p><strong>Cost:</strong> One-time payment</p>
        </div>
        
        <button disabled class="bg-gray-300 text-gray-600 px-6 py-3 rounded font-semibold cursor-not-allowed">Coming Soon</button>
      </div>
    </div>

    <!-- Why Choose These Courses -->
    <section class="bg-gray-50 p-8 rounded-lg">
      <h2 class="text-2xl font-bold mb-6">Why Choose Srini.pro Mastery Courses?</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-xl">✓</span>
          <span class="text-gray-700"><strong>20+ Years of Experience:</strong> Learn from an SAP Integration Architect with decades of real-world expertise</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-xl">✓</span>
          <span class="text-gray-700"><strong>Hands-On Learning:</strong> Practical, project-based curriculum grounded in production scenarios</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-xl">✓</span>
          <span class="text-gray-700"><strong>Lifetime Access:</strong> One payment gives you permanent course access plus all future updates</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-xl">✓</span>
          <span class="text-gray-700"><strong>Industry Best Practices:</strong> Learn techniques used in live enterprise implementations</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-blue-600 font-bold text-xl">✓</span>
          <span class="text-gray-700"><strong>Q&A Support:</strong> Get your questions answered by an expert instructor</span>
        </li>
      </ul>
    </section>

    <!-- Start with Free Courses -->
    <div class="bg-blue-50 p-8 rounded-lg text-center">
      <h2 class="text-2xl font-bold mb-4">New to SAP Integration?</h2>
      <p class="mb-6 text-gray-700">Start with our free foundational courses to build your knowledge base before diving into mastery courses.</p>
      <a href="/free-courses" class="bg-orange-500 text-white px-6 py-2 rounded font-semibold hover:bg-orange-600 transition inline-block">Start Free Courses</a>
    </div>
  </div>
</BaseLayout>
