---
interface Props {
  course: {
    title: string;
    price: number;
    purchaseUrl: string;
  };
}
const { course } = Astro.props;
---

<div class="topbar">
  <div class="wrap topbar-inner">
    <a href="https://srini.pro" class="brand" style="text-decoration:none">srini<span>.pro</span></a>
    <div class="topbar-right">
      <div class="topbar-price">${course.price} <span style="font-size:12px;font-weight:500;color:var(--slate)">one-time</span></div>
      <a class="btn btn-small" href={course.purchaseUrl}>Get the Kit</a>
    </div>
  </div>
</div>

<style>
  .topbar { position: sticky; top: 0; z-index: 50; background: rgba(255, 255, 255, 0.94); backdrop-filter: blur(8px); border-bottom: 1px solid var(--line); }
  .topbar-inner { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .brand { font-family: var(--display); font-weight: 800; font-size: 19px; color: var(--ink); }
  .brand span { color: var(--blue); }
  .topbar-right { display: flex; align-items: center; gap: 16px; }
  .topbar-price { font-family: var(--display); font-weight: 700; font-size: 16px; color: var(--ink); }
  
  @media (max-width: 920px) {
    .topbar-price { display: none; }
  }
  
  @media (max-width: 520px) {
    .topbar-price { display: none; }
  }
</style>
