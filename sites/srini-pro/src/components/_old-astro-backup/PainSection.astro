---
interface Props {
  course: { painPoints?: any[]; };
}
const { course } = Astro.props;
const defaultPainPoints = [
  { tag: "Pain 01", title: '"I froze on a question I actually knew."', description: "Under pressure, unstructured knowledge falls apart. Without rehearsed, well-structured answers, even strong candidates sound uncertain — and interviewers notice." },
  { tag: "Pain 02", title: '"The scenario questions killed me."', description: "Technical definitions get you through round one. Real project scenario questions — error handling, security setup, B2B onboarding — are where hiring decisions actually get made." },
  { tag: "Pain 03", title: '"I\'m from PI/PO. The vocabulary changed."', description: "You have years of integration experience, but interviews are now about CPI, API Management, Event Mesh and BTP. You need to translate your experience into the new stack — fast." }
];
const painPoints = course.painPoints || defaultPainPoints;
---

<section id="problem">
  <div class="wrap">
    <div class="section-head">
      <span class="mono-tag">The real problem</span>
      <h2>You know Integration Suite. But do you know how to answer like a consultant?</h2>
      <p>Most candidates don't fail because they lack knowledge. They fail because they've never rehearsed the exact questions interviewers actually ask — or how experienced consultants answer them.</p>
    </div>
    <div class="pain-grid">
      {painPoints.map((pain) => (
        <div class="pain-card">
          <span class="mono-tag">{pain.tag}</span>
          <h3>{pain.title}</h3>
          <p>{pain.description}</p>
        </div>
      ))}
    </div>
    <p class="pain-close">This kit fixes all three: <strong>the exact questions, expert answers, and real scenarios</strong> — organized so you can revise in days, not months.</p>
  </div>
</section>

<style>
  #problem { padding: 72px 0; }
  .pain-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .pain-card { background: var(--paper-soft); border: 1px solid var(--line); border-radius: 14px; padding: 28px; }
  .pain-card .mono-tag { color: #C24343; display: block; margin-bottom: 12px; }
  .pain-card h3 { font-family: var(--display); font-size: 18px; font-weight: 600; margin-bottom: 10px; line-height: 1.35; }
  .pain-card p { font-size: 15px; color: var(--slate); }
  .pain-close { text-align: center; margin-top: 40px; font-size: 17px; color: var(--ink); font-weight: 500; max-width: 640px; margin-left: auto; margin-right: auto; }
  .pain-close strong { color: var(--blue); }
  
  @media (max-width: 920px) {
    #problem { padding: 56px 0; }
    .pain-grid { grid-template-columns: 1fr; gap: 16px; }
    .pain-card { padding: 24px; }
  }
  
  @media (max-width: 520px) {
    .pain-card { padding: 20px; }
    .pain-card h3 { font-size: 16px; }
    .pain-card p { font-size: 14px; }
    .pain-close { font-size: 15px; margin-top: 32px; }
  }
  
  @media (max-width: 380px) {
    .pain-card { padding: 22px; }
  }
</style>
