---
interface Props {
  course: { faq?: any[]; };
}
const { course } = Astro.props;
const defaultFAQ = [
  { question: "Is this a video course or downloadable documents?", answer: "The kit is delivered as a structured course on school.srini.pro with 5 sections and 8 lessons, containing all five resource documents plus welcome and final-preparation guidance. You get instant access after purchase and can study at your own pace." },
  { question: "I'm a complete beginner. Will this work for me?", answer: "Yes. Questions are tagged Basic, Intermediate and Advanced, so you can start with fundamentals and build up. The long-answer format also teaches you the concepts, not just the answers — many buyers use it as a structured learning path." },
  { question: "I'm an SAP PI/PO consultant. Is this relevant for my transition?", answer: "This is one of the most common profiles the kit was designed for. It covers the full Integration Suite stack — CPI, API Management, Event Mesh, BTP and more — which is exactly the vocabulary and depth interviewers expect from PI/PO consultants moving to the new platform." },
  { question: "Do I have to pay again when the content is updated?", answer: "No. It's a one-time payment with lifetime access and free lifetime updates. When new questions or topic updates (like the 2026 AI capabilities section) are added, they appear in your account at no extra cost." },
  { question: "How is this different from free questions on Google or forums?", answer: "Free lists give you scattered questions with no answers, outdated content, and no structure. This kit gives you 200+ curated questions with expert short and long answers, difficulty tags, a revision cheat sheet, and 50 real project scenarios — organized as a complete preparation system you can finish before your interview date." },
  { question: "How soon do I get access?", answer: "Immediately. As soon as your purchase completes, you get access to the full course and all five resources on school.srini.pro." }
];
const faq = course.faq || defaultFAQ;
---

<section id="faq">
  <div class="wrap">
    <div class="section-head">
      <span class="mono-tag">Questions</span>
      <h2>Frequently asked questions</h2>
    </div>
    <div class="faq-container">
      {faq.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  #faq { padding: 72px 0; }
  .faq-container { max-width: 760px; margin: 0 auto; }
  details { border: 1px solid var(--line); border-radius: 12px; margin-bottom: 12px; background: #fff; }
  summary { cursor: pointer; padding: 20px 24px; font-family: var(--display); font-weight: 600; font-size: 16.5px; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 16px; }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: "+"; font-family: var(--mono); font-size: 20px; color: var(--blue); transition: transform 0.2s ease; flex: none; }
  details[open] summary::after { transform: rotate(45deg); }
  details p { padding: 0 24px 20px; color: var(--slate); font-size: 15px; }
  
  @media (max-width: 920px) {
    #faq { padding: 56px 0; }
  }
  
  @media (max-width: 520px) {
    summary { padding: 16px 18px; font-size: 15.5px; }
    details p { padding: 0 18px 18px; }
  }
</style>
