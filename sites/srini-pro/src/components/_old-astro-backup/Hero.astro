---
interface Props {
  course: {
    title: string;
    subtitle: string;
    description: string;
    heroImage: string;
    price: number;
    purchaseUrl: string;
  };
}
const { course } = Astro.props;
---

<header class="hero">
  <div class="wrap hero-inner">
    <div>
      <span class="eyebrow mono-tag">SAP Integration Suite · Interview Mastery Kit</span>
      <h1>Walk into your SAP Integration Suite interview <em>already knowing the answers.</em></h1>
      <p class="sub">200+ carefully selected interview questions with expert answers — covering CPI, API Management, Event Mesh, B2B, Security, BTP and 50 real-time project scenarios. Everything you need to prepare smarter, sound experienced, and get hired.</p>
      <a class="btn btn-primary" href={course.purchaseUrl}>Get Instant Access — ${course.price}</a>
      <div class="hero-trust">
        <div><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5 6.5 12 13 4.5" stroke="#5AE0A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>One-time payment</div>
        <div><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5 6.5 12 13 4.5" stroke="#5AE0A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Lifetime access</div>
        <div><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5 6.5 12 13 4.5" stroke="#5AE0A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Lifetime updates free</div>
        <div><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8.5 6.5 12 13 4.5" stroke="#5AE0A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Instant download</div>
      </div>
    </div>
    <div class="hero-card">
      <img src={course.heroImage} alt={course.title} loading="eager">
      <div class="stack-line"><span>200+ Interview Q&A (Short + Long)</span><span class="mono-tag">PDF</span></div>
      <div class="stack-line"><span>Top 50 Must-Know Questions</span><span class="mono-tag">PDF</span></div>
      <div class="stack-line"><span>Quick Revision Cheat Sheet</span><span class="mono-tag">PDF</span></div>
      <div class="stack-line"><span>50 Real-Time Project Scenarios</span><span class="mono-tag">PDF</span></div>
      <div class="stack-line"><span>2026 AI Capabilities Guide</span><span class="mono-tag">PDF</span></div>
      <div class="price-row"><span class="price">${course.price}</span><span class="per">one-time · lifetime access</span></div>
      <a class="btn btn-primary" href={course.purchaseUrl} style="width:100%;margin-top:14px;font-size:16px;padding:15px">Buy Now</a>
    </div>
  </div>
</header>

<style>
  .hero { background: linear-gradient(180deg, var(--ink) 0%, var(--ink-soft) 100%); color: #fff; position: relative; overflow: hidden; }
  .hero::after { content: ""; position: absolute; inset: 0; background: radial-gradient(900px 400px at 80% -10%, rgba(10, 110, 209, 0.35), transparent 60%); pointer-events: none; }
  .hero-inner { position: relative; z-index: 1; padding: 76px 0 64px; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 56px; align-items: center; }
  .eyebrow { color: #8FC4F5; margin-bottom: 18px; display: inline-block; border: 1px solid rgba(143, 196, 245, 0.35); padding: 6px 12px; border-radius: 6px; }
  .hero h1 { font-family: var(--display); font-weight: 800; font-size: clamp(32px, 4.6vw, 52px); line-height: 1.12; letter-spacing: -0.01em; margin-bottom: 20px; }
  .hero h1 em { font-style: normal; color: #5AAAF0; }
  .hero .sub { font-size: 18px; color: #C6D6EA; max-width: 560px; margin-bottom: 30px; }
  .hero-trust { display: flex; flex-wrap: wrap; gap: 18px; margin-top: 26px; }
  .hero-trust div { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #AFC6E2; font-weight: 500; }
  .hero-trust svg { flex: none; }
  .hero-card { background: #fff; border-radius: 16px; padding: 26px; box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35); color: var(--ink); }
  .hero-card img { border-radius: 10px; margin-bottom: 18px; }
  .stack-line { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px dashed var(--line); font-size: 14px; color: var(--ink); }
  .stack-line:last-of-type { border-bottom: none; }
  .stack-line .mono-tag { color: var(--blue); letter-spacing: 0.04em; }
  .hero-card .price-row { display: flex; align-items: baseline; gap: 10px; margin-top: 16px; }
  .hero-card .price { font-family: var(--display); font-weight: 800; font-size: 36px; color: var(--ink); }
  .hero-card .per { font-size: 13px; color: var(--slate); }
  
  @media (max-width: 920px) {
    .hero-inner { grid-template-columns: 1fr; padding: 56px 0 48px; gap: 32px; }
  }
  
  @media (max-width: 520px) {
    .hero { padding: 48px 0; }
    .hero h1 { font-size: clamp(24px, 3.5vw, 32px); margin-bottom: 12px; }
    .hero .sub { font-size: 16px; margin-bottom: 20px; }
    .eyebrow { font-size: 11px; padding: 5px 10px; }
    .hero-trust { gap: 12px; }
    .hero-trust div { font-size: 13px; }
    .hero-card { padding: 20px; }
    .stack-line { font-size: 13.5px; }
    .hero-card .price { font-size: 28px; }
  }
  
  @media (max-width: 380px) {
    .btn-primary { font-size: 16px; padding: 16px 20px; width: 100%; }
    .hero-card { padding: 20px; }
    .hero-trust { gap: 12px; }
  }
</style>
