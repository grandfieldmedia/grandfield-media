---
interface Props {
  course: {
    price: number;
    purchaseUrl: string;
  };
}
const { course } = Astro.props;
---

<section class="final-cta">
  <div class="wrap">
    <h2>Your next interview could be days away. Be the candidate who prepared like a professional.</h2>
    <p>200+ questions, expert answers, real scenarios, and a cheat sheet for the final hour — everything for less than the cost of a single certification mock test.</p>
    <a class="btn btn-primary" href={course.purchaseUrl}>Get the Interview Mastery Kit — ${course.price}</a>
    <p class="btn-note">One-time payment · Lifetime access · Lifetime updates free · Instant access</p>
  </div>
</section>

<style>
  .final-cta { text-align: center; background: var(--sky); padding: 72px 0; }
  .final-cta h2 { font-family: var(--display); font-weight: 800; font-size: clamp(26px, 3.6vw, 40px); max-width: 700px; margin: 0 auto 16px; line-height: 1.2; }
  .final-cta p { color: var(--slate); max-width: 560px; margin: 0 auto 30px; font-size: 17px; }
  .btn-primary { background: var(--amber); color: #fff; font-size: 18px; padding: 18px 38px; box-shadow: 0 8px 24px rgba(240, 134, 43, 0.35); border-radius: 10px; cursor: pointer; border: none; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; transition: transform 0.15s ease, box-shadow 0.15s ease; }
  .btn-primary:hover { background: var(--amber-deep); transform: translateY(-2px); }
  .btn-note { font-family: var(--body); font-weight: 500; font-size: 13.5px; color: var(--slate); margin-top: 12px; }
  
  @media (max-width: 920px) {
    .final-cta { padding: 56px 0; }
  }
  
  @media (max-width: 520px) {
    .final-cta { padding: 48px 0; }
    .final-cta h2 { font-size: clamp(22px, 3vw, 28px); margin-bottom: 12px; }
    .final-cta p { font-size: 15px; margin-bottom: 24px; }
    .btn-primary { font-size: 16px; padding: 16px 20px; }
    .btn-note { font-size: 12px; }
  }
</style>
