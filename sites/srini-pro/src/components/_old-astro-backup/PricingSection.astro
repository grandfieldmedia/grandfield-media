---
interface Props {
  course: {
    title: string;
    price: number;
    purchaseUrl: string;
  };
}
const { course } = Astro.props;
---

<section class="pricing" id="pricing">
  <div class="wrap">
    <div class="section-head" style="color:#fff">
      <span class="mono-tag" style="color:#8FC4F5">Simple pricing</span>
      <h2 style="color:#fff">Less than one hour of consulting rates. Prepared for life.</h2>
      <p style="color:#B9CCE6">A single successful interview can change your salary for years. This is the smallest investment you'll make in that outcome.</p>
    </div>
    <div class="price-box">
      <span class="mono-tag">Everything included</span>
      <h3>SAP Integration Suite Interview Mastery Kit</h3>
      <ul class="value-list">
        <li><span>200+ Interview Questions (Short + Long answers)</span><span>PDF</span></li>
        <li><span>Top 50 Must-Know Interview Questions</span><span>PDF</span></li>
        <li><span>Quick Revision Cheat Sheet</span><span>PDF</span></li>
        <li><span>50 Real-Time Project Scenario Questions</span><span>PDF</span></li>
        <li><span>2026 AI Capabilities with Integration Suite</span><span>PDF</span></li>
        <li><span>All future updates to the kit</span><span>FREE</span></li>
      </ul>
      <div class="price-final">
        <span class="amount">${course.price}</span>
        <span class="terms">one-time · no subscription</span>
      </div>
      <a class="btn btn-primary" href={course.purchaseUrl} style="width:100%;margin-top:18px">Get Instant Access</a>
      <div class="guarantee">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 2l8 3.5v5c0 5-3.5 8-8 9.5-4.5-1.5-8-4.5-8-9.5v-5L11 2z" stroke="#0A6ED1" stroke-width="2" stroke-linejoin="round"/><path d="M7.5 11l2.5 2.5 4.5-5" stroke="#0A6ED1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <p><strong>Lifetime access, lifetime updates.</strong> Pay once and every future update to the kit — including new questions and AI-topic refreshes — is yours free, forever.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing { background: linear-gradient(180deg, var(--ink) 0%, #0D2242 100%); color: #fff; padding: 72px 0; }
  .price-box { max-width: 640px; margin: 0 auto; background: #fff; color: var(--ink); border-radius: 18px; padding: 44px 40px; box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45); }
  .price-box .mono-tag { color: var(--blue); text-align: center; display: block; margin-bottom: 8px; }
  .price-box h3 { font-family: var(--display); font-size: 24px; font-weight: 800; text-align: center; margin-bottom: 26px; }
  .value-list { list-style: none; margin-bottom: 26px; }
  .value-list li { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 6px 14px; padding: 12px 0; border-bottom: 1px dashed var(--line); font-size: 15px; }
  .value-list li span:first-child { color: var(--ink); font-weight: 500; }
  .value-list li span:last-child { font-family: var(--mono); font-size: 13px; color: var(--slate); flex: none; }
  .price-final { display: flex; align-items: baseline; justify-content: center; gap: 12px; margin-bottom: 6px; flex-wrap: wrap; text-align: center; }
  .price-final .amount { font-family: var(--display); font-size: 52px; font-weight: 800; }
  .price-final .terms { color: var(--slate); font-size: 14px; }
  .guarantee { display: flex; gap: 14px; align-items: flex-start; background: var(--sky); border-radius: 12px; padding: 18px; margin-top: 24px; }
  .guarantee svg { flex: none; margin-top: 2px; }
  .guarantee p { font-size: 14px; color: var(--ink-soft); }
  .guarantee strong { color: var(--ink); }
  
  @media (max-width: 920px) {
    .pricing { padding: 56px 0; }
    .price-box { padding: 36px 32px; }
  }
  
  @media (max-width: 520px) {
    .price-box { padding: 32px 22px; }
    .price-box h3 { font-size: 20px; }
    .price-final .amount { font-size: 42px; }
    .value-list li { font-size: 14px; }
  }
  
  @media (max-width: 380px) {
    .price-box { padding: 26px 18px; }
    .price-final .amount { font-size: 42px; }
  }
</style>
