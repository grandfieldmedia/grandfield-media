---
interface Props {
  course: { personas?: any[]; };
}
const { course } = Astro.props;
const defaultPersonas = [
  { tag: "Fresher / Beginner", title: "Breaking into SAP Integration Suite", description: "You've done the training but never faced a real interview panel. This kit shows you exactly what gets asked, in what order of difficulty, and how a confident answer sounds — so you never walk in blind." },
  { tag: "PI/PO Consultant", title: "Transitioning to Integration Suite", description: "Your experience is real — it just needs new vocabulary. Map your PI/PO knowledge onto CPI, API Management and BTP, and answer transition questions like someone who has already made the move." },
  { tag: "Experienced Consultant", title: "Aiming for senior roles & better pay", description: "Senior interviews go deep: architecture decisions, security design, B2B onboarding, error-handling strategy. The advanced questions and 50 real-time scenarios prepare you for exactly that conversation." }
];
const personas = course.personas || defaultPersonas;
---

<section class="personas" id="who">
  <div class="wrap">
    <div class="section-head">
      <span class="mono-tag">Who this is for</span>
      <h2>Built for every stage of the SAP integration career path</h2>
    </div>
    <div class="per-grid">
      {personas.map((persona) => (
        <div class="per-card">
          <span class="mono-tag">{persona.tag}</span>
          <h3>{persona.title}</h3>
          <p>{persona.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .personas { background: var(--paper-soft); padding: 72px 0; }
  .per-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .per-card { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 30px; }
  .per-card .mono-tag { color: var(--blue); display: block; margin-bottom: 14px; }
  .per-card h3 { font-family: var(--display); font-size: 18px; font-weight: 700; margin-bottom: 10px; }
  .per-card p { font-size: 15px; color: var(--slate); }
  
  @media (max-width: 920px) {
    .personas { padding: 56px 0; }
    .per-grid { grid-template-columns: 1fr; gap: 16px; }
  }
  
  @media (max-width: 520px) {
    .per-card { padding: 24px; }
    .per-card h3 { font-size: 16px; }
    .per-card p { font-size: 14px; }
  }
  
  @media (max-width: 380px) {
    .per-card { padding: 22px; }
  }
</style>
