---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Features from '@grandfield/shared-ui/components/Features.astro';
import CallToAction from '@grandfield/shared-ui/components/CallToAction.astro';

const features = [
  { title: 'Ready to use', description: 'Download, open, and start — every template works out of the box.' },
  { title: 'No jargon', description: 'Plain-language money tools built for real life, not finance experts.' },
  { title: 'Yours forever', description: 'One-time purchase, instant download, no subscriptions.' },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="bg-primary text-white">
    <div class="mx-auto max-w-6xl px-4 py-24 text-center sm:px-6 lg:px-8">
      <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-accent">Grandfield Money</p>
      <h1 class="mx-auto max-w-3xl text-4xl font-bold leading-tight sm:text-5xl">
        Take control of your money with templates that actually get used.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-200">
        Simple, ready-to-use budgeting and planning tools — no jargon, no financial advice, just practical downloads that help you organize your money.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/products" class="rounded-lg bg-accent px-8 py-3 font-semibold text-primary transition hover:bg-accent-light">
          Browse Products
        </a>
        <a href="/blog" class="rounded-lg border border-white/30 px-8 py-3 font-semibold text-white transition hover:bg-white/10">
          Read the Blog
        </a>
      </div>
    </div>
  </section>

  <Features
    title="Money tools without the overwhelm"
    subtitle="Everything we make is built to be simple enough that you'll actually keep using it."
    items={features}
  />

  <CallToAction
    title="Start organizing your money today"
    subtitle="Browse budgeting templates, planners, and trackers — instant download, yours to keep."
    actions={[
      { text: 'Browse Products', href: '/products' },
      { text: 'Read the Blog', href: '/blog', primary: false },
    ]}
  />
</Layout>
