---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank you" description="Your purchase is complete." noindex={true}>
  <section class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
    <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-accent/15 text-accent">
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h1 class="text-4xl font-bold text-primary">Thank you for your purchase!</h1>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
      We've emailed your download link to the address you used at checkout. It can
      take a minute or two to arrive — check your spam folder if you don't see it.
    </p>
    <p class="mt-6 text-slate-600 dark:text-slate-400">
      Can't find it? <a href="/resend-link" class="font-medium text-accent hover:underline">Re-send my download link</a>.
    </p>
    <a href="/products" class="mt-10 inline-block rounded-lg bg-primary px-8 py-3 font-semibold text-white transition hover:bg-primary-light">
      Back to products
    </a>
  </section>
</Layout>
